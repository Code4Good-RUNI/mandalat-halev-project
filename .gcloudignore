# Same as .gitignore for source uploads, except `.env.server.keys` is NOT listed
# so local `gcloud run deploy --source .` can include dotenvx keys for decryption.
# See https://cloud.google.com/sdk/gcloud/reference/topic/gcloudignore

# env files - secret keys (keep ignoring generic keys; allow .env.server.keys for server deploy)
.env.keys
.env.mobile.keys
apps/mobile/.env.mobile
apps/mobile/.env.mobile.local
apps/server/.env.server.local

# compiled output
dist
tmp
out-tsc

